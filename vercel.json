{
  "buildCommand": null,
  "outputDirectory": ".",
  "framework": null,
  "routes": [
    {
      "src": "/install.sh",
      "dest": "/install.sh"
    },
    {
      "src": "/install.ps1",
      "dest": "/install.ps1"
    },
    {
      "src": "/registry.json",
      "dest": "/registry.json"
    },
    {
      "src": "/api/oauth-config",
      "dest": "/api/oauth-config.js"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
